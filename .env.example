DATABASE_URL="postgresql://user:password@localhost:5432/iguazu?schema=public"
PORT=3000
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change-this-secret

# ============================================================
# FACTURACIÓN ELECTRÓNICA SUNAT
# ============================================================
# Modo: 'beta' (certificado DEMO, pruebas) o 'produccion' (certificado real).
SUNAT_MODO=beta

# Endpoint SOAP de SUNAT. Beta por defecto; cambiar al de producción cuando tengas certificado real.
SUNAT_ENDPOINT=https://e-beta.sunat.gob.pe/ol-ti-itcpfegem-beta/billService

# Credenciales SOAP (Basic auth). En beta suele ser MODDATOS/moddatos.
SUNAT_USUARIO=MODDATOS
SUNAT_CLAVE=moddatos

# Datos del emisor (el hotel).
SUNAT_RUC=20100100100
SUNAT_RAZON_SOCIAL=EMPRESA PRUEBA 25
SUNAT_NOMBRE_COMERCIAL=EMPRESA PRUEBA 25
SUNAT_DIRECCION=CALLE OCHO DE OCTUBRE 123
SUNAT_UBIGEO=140101
SUNAT_CIUDAD=HUANCAYO
SUNAT_DEPARTAMENTO=JUNIN
SUNAT_DISTRITO=HUANCAYO

# Certificado .pfx para firma XML.
# Opción A (recomendado para producción/cloud): base64 del .pfx.
SUNAT_CERT_PFX_BASE64=
# Opción B (local): ruta al archivo .pfx.
SUNAT_CERT_PFX_PATH=certificate/LLAMA-PE-CERTIFICADO-DEMO-20100100100.pfx
# Contraseña del certificado.
SUNAT_CERT_PASSWORD=moddatos

# ============================================================
# RESUMEN DIARIO DE BOLETAS (envío asíncrono)
# ============================================================
# Las boletas (tipo 03) se envían a SUNAT agrupadas en un Resumen Diario
# (sendSummary) y se consultan con getStatus. Intervalo (ms) con el que el
# backend consulta los tickets pendientes. Por defecto 180000 (3 minutos).
SUMMARY_POLL_MS=180000
